# API (REST)
VITE_API_BASE_URL=/api

# Contact form backend (Yandex Cloud Function). Unset -> form runs in demo mode.
# Full endpoint URL, WITHOUT any path (direct function URL treats a path as the
# function id). Example: https://functions.yandexcloud.net/<function-id>
VITE_CONTACT_API_URL=

# Site URL (sitemap, robots.txt)
VITE_SITE_URL=https://example.com

# OpenAPI / Swagger — URL or path for `npm run generate:api`
# Example: https://api.example.com/openapi.json or ./openapi.json
OPENAPI_SPEC_URL=./openapi.json
